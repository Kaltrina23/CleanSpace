<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:CleanSpace.ViewModels"
    x:Class="CleanSpace.Views.Home.HomeOperatore"
    BackgroundColor="#F8FFF1"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.BindingContext>
        <viewmodels:HomeOperatoreViewModel/>
    </ContentPage.BindingContext>

    <Grid RowDefinitions="70,*">

        <!-- HEADER -->
        <Grid Margin="-5,0,-25,0"
              Padding="5,0,0,2"
              BackgroundColor="#D9F99D">    

            <VerticalStackLayout Spacing="0">

                <!-- LOGO -->
                <HorizontalStackLayout Spacing="6"
                                       Padding="0">

                   <Image Source="logo2.png"
                   HeightRequest="75"
                   WidthRequest="75"
                   Aspect="AspectFit"/>

                   <Label Text="Segnalazioni"
                   FontSize="26"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="#1F2937"/>

                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Grid>

        <ScrollView Grid.Row="1">

            <VerticalStackLayout Padding="20"
                                 Spacing="18">

                <HorizontalStackLayout Spacing="10">

                    <Button Text="Tutte"
                            Command="{Binding MostraTutteCommand}"
                            BackgroundColor="#A3D214"
                            TextColor="White"
                            CornerRadius="18"/>

                    <Button Text="In Attesa"
                            Command="{Binding MostraInAttesaCommand}"
                            BackgroundColor="#FACC15"
                            TextColor="Black"
                            CornerRadius="18"/>

                    <Button Text="Approvate"
                            Command="{Binding MostraApprovateCommand}"
                            BackgroundColor="#22C55E"
                            TextColor="White"
                            CornerRadius="18"/>

                </HorizontalStackLayout>

                <CollectionView
                    ItemsSource="{Binding Segnalazioni}">

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Frame CornerRadius="25"
                                   Padding="18"
                                   Margin="0,0,0,10"
                                   BackgroundColor="White"
                                   BorderColor="#E5F0D5">

                                <VerticalStackLayout
                                    Spacing="10">

                                    <Label
                                        Text="{Binding Categoria}"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        TextColor="#1F2937"/>


                                    <Label
                                        Text="{Binding Stato}"
                                        FontSize="15"
                                        TextColor="#84CC16"/>

                                    <Label
                                        Text="{Binding OspiteNome}"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Text="{Binding OspiteCognome}"/>

                                    <Label
                                        Text="{Binding OspiteEmail}"
                                        FontSize="13"
                                        TextColor="Gray"/>

                                    <Label
                                        Text="{Binding Nota}"
                                        FontSize="15"/>

                                    <Label
                                        Text="{Binding Comune}"
                                        FontSize="14"
                                        TextColor="#6B7280"/>

                                    <Label
                                        Text="{Binding Priorita}"
                                        FontAttributes="Bold"
                                        TextColor="#EF4444"/>

                                    <Label
                                        Text="{Binding Data}"
                                        FontSize="12"
                                        TextColor="Gray"/>

                                    <VerticalStackLayout
                                        Spacing="8"
                                        Margin="0,10,0,0">

                                        <Label
                                            Text="Assegna priorità"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="#374151"/>

                                        <HorizontalStackLayout
                                            Spacing="8">

                                            <Button
                                                Text="Alta"
                                                BackgroundColor="#EF4444"
                                                TextColor="White"
                                                CornerRadius="18"
                                                HeightRequest="38"
                                                FontSize="13"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrioritaAltaCommand}"
                                                CommandParameter="{Binding .}"/>

                                            <Button
                                                Text="Media"
                                                BackgroundColor="#F59E0B"
                                                TextColor="White"
                                                CornerRadius="18"
                                                HeightRequest="38"
                                                FontSize="13"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrioritaMediaCommand}"
                                                CommandParameter="{Binding .}"/>

                                            <Button
                                                Text="Bassa"
                                                BackgroundColor="#22C55E"
                                                TextColor="White"
                                                CornerRadius="18"
                                                HeightRequest="38"
                                                FontSize="13"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrioritaBassaCommand}"
                                                CommandParameter="{Binding .}"/>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                    <HorizontalStackLayout
                                        Spacing="12"
                                        Margin="0,10,0,0">

                                        <Button
                                            Text="Approva"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApprovaCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#22C55E"
                                            TextColor="White"
                                            CornerRadius="18"/>

                                        <Button
                                            Text="Elimina"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EliminaCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#EF4444"
                                            TextColor="White"
                                            CornerRadius="18"/>

                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                            </Frame>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>