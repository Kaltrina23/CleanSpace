<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:CleanSpace.ViewModels"
    xmlns:components="clr-namespace:CleanSpace.Views.Components"
    x:Class="CleanSpace.Views.Home.HomeUtente"

    BackgroundColor="#F8FFF1"
    NavigationPage.HasNavigationBar="False">

    <!-- CONTENUTO -->
    <ScrollView VerticalScrollBarVisibility="Never">

        <VerticalStackLayout
            Padding="25,20,25,90"
            Spacing="22">

            <components:UtenteHeader/>

            <components:SegnalazioneCard/>

            <components:InfoCard/>

            <Button
                Text="Profilo"
                Clicked="ApriProfilo"
                HeightRequest="55"
                CornerRadius="28"
                BackgroundColor="#A3D214"
                TextColor="White"
                FontAttributes="Bold"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>