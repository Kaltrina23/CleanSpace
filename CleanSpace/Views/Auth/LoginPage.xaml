<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CleanSpace.Views.Auth.LoginPage"
             BackgroundColor="#EEF7DF"
             NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- SFONDO -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="0,1">

                <GradientStop Color="#EEF7DF"
                              Offset="0.0"/>

                <GradientStop Color="#F8FFF1"
                              Offset="1.0"/>

            </LinearGradientBrush>
        </Grid.Background>

        <!-- CONTENUTO -->
        <VerticalStackLayout Padding="25,15,25,15"
                             VerticalOptions="Center"
                             Spacing="10">

            <!-- LOGO -->
            <Image Source="logo2.png"
                   HeightRequest="180"
                   WidthRequest="180"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"/>

            <!-- TITOLI -->
            <VerticalStackLayout Spacing="5">

                <Label Text="Bentornato"
                       FontSize="34"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#1F2937"/>

                <Label Text="Segnala e proteggi il tuo ambiente"
                       FontSize="15"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="#6B7280"/>
            </VerticalStackLayout>

            <!-- CARD LOGIN -->
            <Frame CornerRadius="35"
                   Padding="20"
                   BackgroundColor="White"
                   BorderColor="#E5F0D5"
                   HasShadow="False">

                <VerticalStackLayout Spacing="20">

                    <!-- EMAIL -->
                    <Frame CornerRadius="18"
                           Padding="15,5"
                           BackgroundColor="#F9FFF3"
                           BorderColor="#E5F0D5"
                           HasShadow="False">

                        <Entry Placeholder="Email"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               TextColor="#1F2937"
                               PlaceholderColor="#9CA3AF"/>
                    </Frame>

                    <!-- PASSWORD -->
                    <Frame CornerRadius="18"
                           Padding="15,5"
                           BackgroundColor="#F9FFF3"
                           BorderColor="#E5F0D5"
                           HasShadow="False">

                        <Entry Placeholder="Password"
                               IsPassword="True"
                               Text="{Binding Password}"
                               TextColor="#1F2937"
                               PlaceholderColor="#9CA3AF"/>
                    </Frame>

                    <!-- BOTTONE LOGIN -->
                    <Button Text="Accedi"
                            Command="{Binding LoginCommand}"
                            HeightRequest="55"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="18"
                            BackgroundColor="#A3D214"
                            TextColor="White"/>

                    <!-- LOADING -->
                    <ActivityIndicator 
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="#84CC16"/>

                    <!-- DIVISORE -->
                    <HorizontalStackLayout Spacing="10"
                                           HorizontalOptions="Center">

                        <BoxView HeightRequest="1"
                                 WidthRequest="70"
                                 Color="#D9F99D"
                                 VerticalOptions="Center"/>

                        <Label Text="OPPURE"
                               TextColor="#84CC16"
                               FontAttributes="Bold"/>

                        <BoxView HeightRequest="1"
                                 WidthRequest="70"
                                 Color="#D9F99D"
                                 VerticalOptions="Center"/>

                    </HorizontalStackLayout>

                    <!-- ACCESSO OSPITE -->
                    <Button Text="Entra come ospite"
                            Command="{Binding GuestLoginCommand}"
                            HeightRequest="52"
                            CornerRadius="18"
                            BackgroundColor="#F3F8EA"
                            BorderColor="#D9F99D"
                            BorderWidth="1.5"
                            TextColor="#4D7C0F"
                            FontAttributes="Bold"/>

                </VerticalStackLayout>

            </Frame>

            <!-- REGISTRAZIONE -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="5">

                <Label Text="Non hai un account?"
                       TextColor="#6B7280"
                       FontSize="14"/>

                <Label Text="Registrati"
                       TextColor="#84CC16"
                       FontAttributes="Bold"
                       FontSize="14"/>

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Grid>

</ContentPage>