<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CleanSpace.Views.Segnala.CategoriePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8FFF1">

    <Grid RowDefinitions="100,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              Padding="15,5,25,25">

            <!-- SFONDO HEADER -->
            <Frame BackgroundColor="#D9F99D"
                   CornerRadius="0"
                   HasShadow="False"
                   Padding="0"
                   Margin="-30,-60,-30,0"/>

            <VerticalStackLayout Spacing="0">

                <!-- LOGO + TITOLO -->
                <HorizontalStackLayout Spacing="12">

                    <Image Source="logo2.png"
                           HeightRequest="70"
                           WidthRequest="70"
                           Aspect="AspectFit"/>

                    <Label Text="Categorie"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#1F2937"
                           VerticalOptions="Center"/>

                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Grid>

        <!-- CONTENUTO -->
        <ScrollView Grid.Row="1"
                    VerticalScrollBarVisibility="Never">

            <VerticalStackLayout Padding="25,10,25,30"
                                 Spacing="18">

                <!-- LISTA CATEGORIE -->
                <VerticalStackLayout
                    Spacing="16"
                    BindableLayout.ItemsSource="{Binding Categorie}">

                    <BindableLayout.ItemTemplate>

                        <DataTemplate>

                            <!-- CARD -->
                            <Frame CornerRadius="28"
                                   Padding="0"
                                   BackgroundColor="White"
                                   BorderColor="#E5F0D5"
                                   HasShadow="False">

                                <!-- CLICK CARD -->
                                <Frame.GestureRecognizers>

                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelezionaCategoriaCommand}"
                                        CommandParameter="{Binding .}"/>

                                </Frame.GestureRecognizers>

                                <!-- CONTENUTO CARD -->
                                <Grid ColumnDefinitions="80,*,50"
                                      Padding="18">

                                    <!-- ICONA -->
                                    <Frame HeightRequest="55"
                                           WidthRequest="55"
                                           CornerRadius="28"
                                           BackgroundColor="#D9F99D"
                                           Padding="0"
                                           VerticalOptions="Center"
                                           HasShadow="False">

                                        <Label Text="♻"
                                               FontSize="24"
                                               TextColor="#65A30D"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>

                                    <!-- TESTI -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="3"
                                                         VerticalOptions="Center">

                                        <Label Text="{Binding Nome}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="#1F2937"/>

                                        <Label Text="Tocca per continuare"
                                               FontSize="13"
                                               TextColor="#6B7280"/>

                                    </VerticalStackLayout>

                                    <!-- FRECCIA -->
                                    <Label Grid.Column="2"
                                           Text="➜"
                                           FontSize="22"
                                           TextColor="#84CC16"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"/>

                                </Grid>

                            </Frame>

                        </DataTemplate>

                    </BindableLayout.ItemTemplate>

                </VerticalStackLayout>

                <!-- BOTTONE -->
                <Button Text="Torna alla Home"
                        Clicked="ClickHomeUtente"
                        HeightRequest="55"
                        CornerRadius="20"
                        Margin="0,10,0,0"
                        BackgroundColor="#A3D214"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="17"/>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>