<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CleanSpace.Views.Components.InfoCard">

    <Frame CornerRadius="22"
           Padding="16,14"
           Margin="0,0,0,25"
           BackgroundColor="#F3F8EA"
           BorderColor="#E5F0D5"
           HasShadow="False"
           VerticalOptions="End">

        <HorizontalStackLayout
            Spacing="14"
            VerticalOptions="Center">

            
            <Frame HeightRequest="48"
                   WidthRequest="48"
                   CornerRadius="24"
                   BackgroundColor="#D9F99D"
                   Padding="0"
                   HasShadow="False"
                   VerticalOptions="Center">

                <Label Text="🌱"
                       FontSize="20"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Frame>

            <VerticalStackLayout
                Spacing="2"
                VerticalOptions="Center">

                <Label Text="Ogni segnalazione conta"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#365314"/>

                <Label Text="Grazie per il tuo contributo all’ambiente"
                       FontSize="13"
                       TextColor="#6B7280"/>

            </VerticalStackLayout>

        </HorizontalStackLayout>

    </Frame>

</ContentView>