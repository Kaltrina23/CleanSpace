<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CleanSpace.Views.Components"
    x:Class="CleanSpace.Views.Components.CategoriaCard">

    <Frame
        CornerRadius="25"
        Padding="25"
        BackgroundColor="White"
        HasShadow="False"
        BorderColor="#F0F0F0">

        <Grid ColumnDefinitions="70,*,60">

            <Frame
                
                WidthRequest="55"
                HeightRequest="55"
                CornerRadius="30"
                BackgroundColor="#DFF99D"
                Padding="10"
                HasShadow="False"
                VerticalOptions="Center">

                <Image
                    Source="{Binding Icona, Source={RelativeSource AncestorType={x:Type local:CategoriaCard}}}" />

            </Frame>

            <VerticalStackLayout
                Grid.Column="1"
                Spacing="2"
                VerticalOptions="Center">

                <Label
                    Text="{Binding Titolo, Source={RelativeSource AncestorType={x:Type local:CategoriaCard}}}"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#2D2D2D" />

                <Label
                    Text="{Binding Descrizione, Source={RelativeSource AncestorType={x:Type local:CategoriaCard}}}"
                    FontSize="14"
                    TextColor="#9A9A9A" />

            </VerticalStackLayout>

            <Button
                Grid.Column="2"
                Text="➜"
                FontSize="22"
                BackgroundColor="Transparent"
                TextColor="#B7D400"
                Command="{Binding Command, Source={RelativeSource AncestorType={x:Type local:CategoriaCard}}}"
                CommandParameter="{Binding CommandParameter, Source={RelativeSource AncestorType={x:Type local:CategoriaCard}}}" />

        </Grid>

    </Frame>

</ContentView>