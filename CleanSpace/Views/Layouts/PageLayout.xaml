<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CleanSpace.Views.Layouts.PageLayout"

    x:Name="this">

    <Grid RowDefinitions="100,*"
          BackgroundColor="#F8FFF1">

        <!-- HEADER -->
        <Grid
            Grid.Row="0"
            BackgroundColor="#D9F99D"
            Padding="15,15,15,10">

            <HorizontalStackLayout
                Spacing="12"
                VerticalOptions="Center">

                <Image
                    Source="logo2.png"
                    HeightRequest="55"
                    WidthRequest="55"/>

                <Label
                    Text="Tina "
                    FontSize="28"
                    FontAttributes="Bold"
                    VerticalOptions="Center"
                    TextColor="#1F2937"/>

            </HorizontalStackLayout>

        </Grid>

        <!-- CONTENUTO -->
        <ScrollView Grid.Row="1">

            <ContentPresenter x:Name="PageContent"/>

        </ScrollView>

    </Grid>

</ContentView>