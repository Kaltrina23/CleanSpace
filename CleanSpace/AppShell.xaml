<?xml version="1.0" encoding="UTF-8" ?>

<Shell
    x:Class="CleanSpace.AppShell"

    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:auth="clr-namespace:CleanSpace.Views.Auth"
    xmlns:home="clr-namespace:CleanSpace.Views.Home"

    Shell.NavBarIsVisible="False"
    Shell.FlyoutBehavior="Disabled"

    Shell.TabBarBackgroundColor="White"
    Shell.TabBarForegroundColor="#84CC16"
    Shell.TabBarTitleColor="#84CC16"
    Shell.TabBarUnselectedColor="#A3A3A3">

    <!-- LOGIN -->
    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate auth:LoginPage}" />

    <!-- AREA UTENTE -->
    <TabBar Route="utenteTabs">

        <ShellContent
            Route="homeUtente"
            Title="Home"
            Icon="home.svg"
            ContentTemplate="{DataTemplate home:HomeUtente}" />

    </TabBar>

    <!-- AREA OPERATORE -->
    <TabBar Route="operatoreTabs">

        <ShellContent
            Route="homeOperatore"
            Title="Home"
            Icon="home.svg"
            ContentTemplate="{DataTemplate home:HomeOperatore}" />

    </TabBar>

</Shell>